# Server Configuration
PORT=4000
CONFIG_PATH=./config.json
# Externally-reachable base URL of this Orchestration Engine instance, used to build
# provider callback URLs for the async request-reply flow (POST /public/graphql/async).
# Must be set to a real, provider-reachable URL outside local development.
OE_PUBLIC_URL=http://localhost:4000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=orchestration_engine
DB_SSLMODE=disable

# Observability
SERVICE_NAME=orchestration-engine
SERVICE_VERSION=dev
OTEL_METRICS_EXPORTER=prometheus
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_EXPORTER_OTLP_INSECURE=true

# Audit
ENABLE_AUDIT=true
